# Runtime environment for the AWD training campaign.
# Copy to .env, fill in values, then:
#     source .env
# before any of the launch scripts. AWS credentials come from your
# normal aws CLI config (~/.aws/credentials) — they are NOT in this file.

# ── Weights & Biases ──────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=awd
WANDB_ENTITY=

# ── S3 ────────────────────────────────────────────────────────────
# Checkpoint bucket — workers read+write. Create via setup_aws.sh.
CKPT_BUCKET=s3://awd-checkpoints

# Optional: pre-built venv tarball. Leave empty to let bootstrap.sh
# pip-install the (small) CIFAR stack on each worker.
VENV_S3_URL=

# Optional: EBS snapshot containing a pre-extracted CIFAR-100. CIFAR
# is small enough to download on every worker — only set this if you
# specifically want the EBS path.
DATA_SNAPSHOT=

# ── Repo ──────────────────────────────────────────────────────────
# bootstrap.sh fetches scripts/orchestrate.sh from this repo.
REPO_URL=https://github.com/<you>/awd.git
REPO_REF=main

# ── Campaign controls ─────────────────────────────────────────────
# Ordered list of AZs the watchdog rotates through. First AZ is tried
# first; if every AZ rejects, watchdog sleeps CAPACITY_SLEEP_SEC and
# starts over.
CAMPAIGN_AZS="us-west-2d us-west-2c us-west-2b us-west-2a"

# How many workers to keep alive.
TARGET_WORKERS=2

# Spot instance type. CIFAR fits on a single A10G/L4.
INSTANCE_TYPE=g5.xlarge

# Tag prefix on EC2 instances; lets multiple campaigns coexist.
CAMPAIGN=awd

# ── AWS region hint ───────────────────────────────────────────────
AWS_DEFAULT_REGION=us-west-2

# ── Subnets per AZ ────────────────────────────────────────────────
# Filled in once per account. Format: SUBNET_<az with - replaced by _>
# SUBNET_us_west_2a=subnet-xxxxxxxx
# SUBNET_us_west_2b=subnet-xxxxxxxx
# SUBNET_us_west_2c=subnet-xxxxxxxx
# SUBNET_us_west_2d=subnet-xxxxxxxx

# ── Security ──────────────────────────────────────────────────────
# AMI=ami-...                # Deep Learning Base AMI for AWS_DEFAULT_REGION
# SG=sg-...                  # security group id
# KEY=                       # optional EC2 key pair name
